#!/usr/bin/env bash
#MISE description="Benchmark stdin formatting across representative CMake files."
#MISE depends=["build"]

set -euo pipefail

plugin_path="$PWD/target/wasm32-unknown-unknown/release/dprint_cmakefmt.wasm"
dprint_path="$(command -v dprint)"
cmakefmt_manifest="$PWD/third_party/cmakefmt-rust-1.6.0/Cargo.toml"
cmakefmt_native="$PWD/third_party/cmakefmt-rust-1.6.0/target/release/cmakefmt"

file_limit="${BENCH_FILE_LIMIT:-all}"
repeat_count="${BENCH_REPEAT_COUNT:-40}"
warmup="${BENCH_WARMUP:-2}"
runs="${BENCH_RUNS:-4}"
source_dir="support/bench-fixtures"

tmp_dir="$(mktemp -d)"
trap 'rm -rf "$tmp_dir"' EXIT

cargo build --quiet --release --manifest-path "$cmakefmt_manifest" --bin cmakefmt

file_list="$tmp_dir/files.txt"
config_path="$tmp_dir/dprint.json"

find "$source_dir" -type f \
  \( -name 'CMakeLists.txt' -o -name 'CMakeLists.txt.in' -o -name '*.cmake' \) \
  | sort > "$file_list"

if [[ "$file_limit" != "all" ]]; then
  limited_file_list="$tmp_dir/files.limited.txt"
  head -n "$file_limit" "$file_list" > "$limited_file_list"
  file_list="$limited_file_list"
fi

repeated_file_list="$tmp_dir/files.repeated.txt"
for _ in $(seq 1 "$repeat_count"); do
  cat "$file_list" >> "$repeated_file_list"
done
file_list="$repeated_file_list"
file_count="$(wc -l < "$file_list" | tr -d ' ')"

cat > "$config_path" <<JSON
{
  "plugins": ["$plugin_path"],
  "cmakefmt": {}
}
JSON

export DPRINT_BENCH_FILE_LIST="$file_list"
export DPRINT_BENCH_CONFIG="$config_path"
export DPRINT_BENCH_DPRINT="$dprint_path"
export DPRINT_BENCH_CMAKEFMT="$cmakefmt_native"

native_command='while IFS= read -r file; do "$DPRINT_BENCH_CMAKEFMT" < "$file" > /dev/null; done < "$DPRINT_BENCH_FILE_LIST"'
dprint_command='while IFS= read -r file; do "$DPRINT_BENCH_DPRINT" fmt --stdin "$file" --config "$DPRINT_BENCH_CONFIG" --config-discovery=false < "$file" > /dev/null; done < "$DPRINT_BENCH_FILE_LIST"'

echo "Benchmarking stdin formatting over $file_count CMake files from $source_dir."
echo "Set BENCH_REPEAT_COUNT, BENCH_FILE_LIMIT, BENCH_RUNS, or BENCH_WARMUP to adjust rounds."

hyperfine \
  --warmup "$warmup" \
  --runs "$runs" \
  --command-name "native cmakefmt" "$native_command" \
  --command-name "dprint wasm plugin" "$dprint_command"
